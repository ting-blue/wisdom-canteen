/* pages/my-meal/my-meal.wxss */

.container {
  min-height: 100vh;
  background-color: #f5f7fb;
  padding: 20rpx;
}

/* 日期筛选栏 */
.date-filter {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  margin-bottom: 20rpx;
}

.filter-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 28rpx;
  color: #333;
}

.arrow {
  font-size: 24rpx;
  color: #999;
}

.stat-summary {
  font-size: 26rpx;
  color: #999;
}

/* 日期分组 */
.date-group {
  margin-bottom: 20rpx;
}

.date-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  padding: 16rpx 10rpx;
  background: transparent;
}

.date-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.date-calorie {
  font-size: 26rpx;
  color: #ff6b6b;
}

/* 用餐记录卡片 */
.meal-items {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.meal-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.meal-item {
  display: flex;
  align-items: center;
  padding: 30rpx 24rpx;
  margin-bottom: 16rpx;
  background: #fff;
  border-radius: 16rpx;
  border-bottom: none;
}

.meal-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 16rpx;
  margin-right: 24rpx;
  background-color: #f5f5f5;
}

.meal-info {
  flex: 1;
}

.meal-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.meal-detail {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 6rpx;
}

.meal-time {
  font-size: 22rpx;
  color: #ccc;
}

.meal-img-placeholder {
  width: 100rpx;
  height: 100rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #ff9a56, #ff6b6b);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}
.meal-img-text {
  font-size: 44rpx;
  color: #fff;
  font-weight: 700;
}

.meal-delete {
  padding: 16rpx;
  color: #ff6b6b;
  font-size: 36rpx;
  opacity: 0.6;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
  text-align: center;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-state text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.empty-tip {
  font-size: 24rpx;
  color: #ccc;
}

/* 最新菜品卡片 */
.dish-card {
  margin: 16rpx 30rpx;
  background: linear-gradient(145deg, #ffffff, #f8f9fa);
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  padding: 24rpx 30rpx;
}

.dish-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.dish-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.dish-time {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.time-label {
  font-size: 22rpx;
  color: #999;
}

.time-value {
  font-size: 22rpx;
  color: #666;
}

.dish-body {
  padding-top: 20rpx;
}

.dish-name-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.dish-name {
  font-size: 44rpx;
  font-weight: 700;
  color: #2d3436;
}

.dish-position {
  font-size: 26rpx;
  color: #6c5ce7;
  background: #f0edff;
  padding: 6rpx 20rpx;
  border-radius: 30rpx;
}

.nutrition-grid {
  display: flex;
  justify-content: space-around;
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 20rpx 0;
  margin-bottom: 16rpx;
}

.nutrition-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.nutrition-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #2d3436;
}

.nutrition-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.confidence-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding-top: 8rpx;
}

.confidence-label {
  font-size: 24rpx;
  color: #666;
}

.confidence-bar {
  flex: 1;
  height: 8rpx;
  background: #e9ecef;
  border-radius: 10rpx;
  overflow: hidden;
}

.confidence-fill {
  height: 100%;
  background: linear-gradient(90deg, #6c5ce7, #a29bfe);
  border-radius: 10rpx;
  transition: width 0.3s;
}

.confidence-value {
  font-size: 24rpx;
  color: #6c5ce7;
  font-weight: 600;
  min-width: 60rpx;
  text-align: right;
}

.dish-footer {
  margin-top: 16rpx;
  display: flex;
  justify-content: flex-end;
}

.refresh-btn {
  background: transparent;
  border: 1rpx solid #ddd;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #666;
  padding: 10rpx 30rpx;
  line-height: 1.6;
}