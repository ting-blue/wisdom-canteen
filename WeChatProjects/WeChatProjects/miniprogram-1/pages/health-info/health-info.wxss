/* pages/health-info/health-info.wxss */

.container {
  min-height: 100vh;
  background-color: #f5f7fb;
  padding: 30rpx;
  padding-bottom: 60rpx;
}

/* 进度条 */
.progress {
  margin-bottom: 40rpx;
}

.progress-bar {
  height: 8rpx;
  background: linear-gradient(90deg, #4CAF50, #8BC34A);
  border-radius: 4rpx;
  margin-bottom: 16rpx;
}

.progress-text {
  font-size: 26rpx;
  color: #4CAF50;
}

/* 标题 */
.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: #999;
}

/* 表单滚动区域 */
.form-scroll {
  height: calc(100vh - 300rpx);
}

/* 表单项 */
.form-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.item-label {
  display: flex;
  align-items: baseline;
  margin-bottom: 20rpx;
}

.label-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.label-text {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  flex: 1;
}

.label-unit {
  font-size: 24rpx;
  color: #999;
}

.label-hint {
  font-size: 24rpx;
  color: #999;
  margin-left: 8rpx;
}

.input-wrapper {
  margin-bottom: 16rpx;
}

.input-field {
  width: 100%;
  height: 80rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 0 20rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.slider {
  margin-top: 8rpx;
}

/* 性别选择 */
.gender-group {
  display: flex;
  gap: 30rpx;
}

.gender-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.gender-item.active {
  background: #e8f5e9;
  border-color: #4CAF50;
}

.gender-icon {
  font-size: 60rpx;
  margin-bottom: 8rpx;
}

.gender-text {
  font-size: 28rpx;
  color: #666;
}

/* 活动水平选择 */
.activity-group {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.activity-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
}

.activity-item.active {
  background: #e8f5e9;
  border-color: #4CAF50;
}

.activity-icon {
  font-size: 44rpx;
  margin-right: 20rpx;
}

.activity-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  width: 140rpx;
}

.activity-desc {
  font-size: 24rpx;
  color: #999;
  flex: 1;
}

/* 饮食目标选择 */
.goal-group {
  display: flex;
  gap: 20rpx;
}

.goal-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
}

.goal-item.active {
  background: #e8f5e9;
  border-color: #4CAF50;
}

.goal-icon {
  font-size: 44rpx;
  margin-bottom: 8rpx;
}

.goal-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.goal-desc {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
  text-align: center;
}

/* 过敏选项 */
.allergy-group {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.allergy-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: #f8f8f8;
  border-radius: 48rpx;
  border: 2rpx solid transparent;
  font-size: 26rpx;
}

.allergy-item.active {
  background: #ffebee;
  border-color: #f44336;
}

/* 疾病选项 */
.disease-group {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.disease-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: #f8f8f8;
  border-radius: 48rpx;
  border: 2rpx solid transparent;
  font-size: 26rpx;
}

.disease-item.active {
  background: #ffebee;
  border-color: #f44336;
}

/* 按钮 */
.btn-group {
  margin-top: 40rpx;
  margin-bottom: 60rpx;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #4CAF50, #8BC34A);
  border-radius: 44rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  border: none;
}

.skip-btn {
  width: 100%;
  height: 88rpx;
  background: transparent;
  border-radius: 44rpx;
  color: #999;
  font-size: 30rpx;
  border: 1rpx solid #ddd;
}

/* 自定义输入区域 */
.custom-input-area {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 24rpx;
}

.custom-input {
  flex: 1;
  height: 72rpx;
  background: #f8f8f8;
  border-radius: 36rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.add-btn {
  width: 120rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-radius: 36rpx;
  color: #fff;
  font-size: 28rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-btn::after {
  border: none;
}

/* 自定义标签 */
.custom-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
}

.custom-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 20rpx;
  background: #e8f5e9;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #2e7d32;
}

.tag-remove {
  font-size: 28rpx;
  color: #999;
  margin-left: 8rpx;
}

/* 选中状态的样式 */
.allergy-item.active,
.disease-item.active {
  background: #4CAF50 !important;
  color: #fff !important;
  border-color: #4CAF50 !important;
}

.allergy-item.active text,
.disease-item.active text {
  color: #fff !important;
}