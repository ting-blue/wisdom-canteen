/* pages/health/health.wxss */

.container {
  min-height: 100vh;
  background-color: #f5f7fb;
  padding: 30rpx;
  padding-bottom: 60rpx;
}

/* 头部 */
.header {
  text-align: center;
  margin-bottom: 40rpx;
  padding: 20rpx 0;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: #999;
}

/* 卡片 */
.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.card-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.card-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

/* 表单项 */
.form-item {
  margin-bottom: 30rpx;
}

.item-label {
  display: flex;
  align-items: baseline;
  margin-bottom: 16rpx;
}

.label-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.label-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.label-unit {
  font-size: 24rpx;
  color: #999;
  margin-left: 8rpx;
}

.label-optional, .label-hint {
  font-size: 24rpx;
  color: #999;
  margin-left: 8rpx;
}

.input-wrapper {
  margin-bottom: 12rpx;
}

.input-field {
  width: 100%;
  height: 80rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 0 20rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.slider {
  margin-top: 8rpx;
}

/* 性别选择 */
.gender-group {
  display: flex;
  gap: 30rpx;
}

.gender-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.gender-item.active {
  background: #e8f5e9;
  border-color: #4CAF50;
}

.gender-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.gender-text {
  font-size: 28rpx;
  color: #666;
}

/* 活动水平 */
.activity-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.activity-item {
  flex: 1;
  min-width: 160rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
}

.activity-item.active {
  background: #e8f5e9;
  border-color: #4CAF50;
}

.activity-icon {
  font-size: 40rpx;
}

.activity-text {
  font-size: 26rpx;
  color: #666;
}

/* 饮食目标 */
.goal-group {
  display: flex;
  gap: 20rpx;
}

.goal-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
}

.goal-item.active {
  background: #e8f5e9;
  border-color: #4CAF50;
}

.goal-icon {
  font-size: 44rpx;
  margin-bottom: 8rpx;
}

.goal-text {
  font-size: 28rpx;
  color: #666;
}

/* 忌口/过敏 */
.allergy-group,
.disease-group {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.allergy-item,
.disease-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: #f8f8f8;
  border-radius: 48rpx;
  border: 2rpx solid transparent;
  font-size: 26rpx;
  color: #333;
}

.allergy-item.active,
.disease-item.active {
  background: #e8f5e9;
  border-color: #4CAF50;
}

/* 自定义输入 */
.custom-input-area {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 20rpx;
}

.custom-input {
  flex: 1;
  height: 72rpx;
  background: #f8f8f8;
  border-radius: 36rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.add-btn {
  width: 120rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-radius: 36rpx;
  color: #fff;
  font-size: 28rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-btn::after {
  border: none;
}

/* 自定义标签 */
.custom-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
}

.custom-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 20rpx;
  background: #e8f5e9;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #2e7d32;
}

.tag-remove {
  font-size: 28rpx;
  color: #999;
  margin-left: 8rpx;
}

/* 保存按钮 */
.btn-group {
  margin-top: 40rpx;
  margin-bottom: 60rpx;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #4CAF50, #8BC34A);
  border-radius: 44rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
}

/* 强制修复忌口选项样式 - 放在文件最后 */
.allergy-item {
  background: #f5f5f5 !important;
  border: 2rpx solid #ddd !important;
  color: #333 !important;
}

.allergy-item.active {
  background: #4CAF50 !important;
  border-color: #4CAF50 !important;
  color: #fff !important;
}

.report-card {
  margin: 30rpx;
  padding: 40rpx;
  background: #fff;
  border-radius: 24rpx;
}
.report-header {
  font-size: 40rpx;
  font-weight: 700;
  text-align: center;
  margin-bottom: 10rpx;
}
.report-date {
  text-align: center;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 30rpx;
}
.report-stats {
  display: flex;
  justify-content: space-around;
  padding: 24rpx;
  background: #f5f7fb;
  border-radius: 16rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
}
.report-dishes {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 20rpx;
  padding: 16rpx;
  background: #fff9c4;
  border-radius: 12rpx;
}
.report-content {
  font-size: 30rpx;
  line-height: 1.8;
  color: #333;
  padding: 24rpx;
  background: #f0fdf4;
  border-radius: 16rpx;
}

