/* pages/yunshipu/yunshipu.wxss */

page {
  background-color: #f5f7fb;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(180deg, #f0f4fa 0%, #f5f7fb 100%);
  /* 安全区域适配 */
  padding-top: constant(safe-area-inset-top);  /* iOS 11.0 */
  padding-top: env(safe-area-inset-top);       /* iOS 11.2+ */
  box-sizing: border-box;
}

/* 头部导航 */
.chat-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  /* 增加顶部内边距，避免被灵动岛遮挡 */
  padding: 88rpx 32rpx 24rpx;
  background: rgba(255, 255, 255, 0.96);
  backdrop-filter: blur(20px);
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
  /* 确保头部在安全区域内 */
  position: relative;
  z-index: 10;
}

/* 针对不同机型的额外适配 */
@media (prefers-safe-area-inset-top) {
  .chat-header {
    padding-top: calc(88rpx + constant(safe-area-inset-top));
    padding-top: calc(88rpx + env(safe-area-inset-top));
  }
}

.header-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #f0f0f0;
}

.back-icon {
  font-size: 40rpx;
  color: #333;
  font-weight: 500;
}

.header-title {
  text-align: center;
}

.title-text {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.title-sub {
  display: block;
  font-size: 22rpx;
  color: #888;
  margin-top: 4rpx;
}

.header-placeholder {
  width: 64rpx;
}

/* 聊天区域 */
.chat-list {
  flex: 1;
  padding: 24rpx 24rpx 0;
  box-sizing: border-box;
}

/* 欢迎卡片 */
.welcome-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx;
  text-align: center;
}

.welcome-avatar {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  box-shadow: 0 16rpx 32rpx rgba(102, 126, 234, 0.3);
}

.welcome-avatar .avatar-icon {
  font-size: 64rpx;
}

.welcome-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 16rpx;
}

.welcome-desc {
  font-size: 28rpx;
  color: #888;
  line-height: 1.5;
}

/* 消息列表 */
.message-list {
  display: flex;
  flex-direction: column;
}

.message-item {
  display: flex;
  margin-bottom: 32rpx;
  align-items: flex-start;
}

.message-item.assistant {
  justify-content: flex-start;
}

.message-item.user {
  justify-content: flex-end;
}

/* 头像 */
.message-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.user-avatar {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  order: 2;
  margin-left: 16rpx;
}

.message-avatar .avatar-icon {
  font-size: 36rpx;
}

/* 气泡 */
.message-bubble {
  max-width: 70%;
  padding: 20rpx 28rpx;
  border-radius: 28rpx;
  word-wrap: break-word;
}

.assistant-bubble {
  background-color: #ffffff;
  color: #333;
  margin-left: 16rpx;
  border-top-left-radius: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.user-bubble {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  margin-right: 16rpx;
  border-top-right-radius: 8rpx;
}

.message-content {
  font-size: 30rpx;
  line-height: 1.5;
  white-space: pre-wrap;
}

.user-bubble .message-content {
  color: #fff;
}

/* 加载动画 */
.loading-indicator {
  display: flex;
  align-items: flex-start;
  margin-bottom: 32rpx;
}

.loading-bubble {
  padding: 20rpx 28rpx;
}

.dot-typing {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  background-color: #999;
  border-radius: 50%;
  animation: dotPulse 1.2s infinite ease-in-out;
}

.dot:nth-child(2) {
  animation-delay: 0.2s;
}

.dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes dotPulse {
  0%, 60%, 100% {
    transform: scale(0.8);
    opacity: 0.5;
  }
  30% {
    transform: scale(1.2);
    opacity: 1;
  }
}

/* 输入区域 */
.input-area {
  background: rgba(255, 255, 255, 0.96);
  backdrop-filter: blur(20px);
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
  padding: 20rpx 24rpx 32rpx;
}

.input-wrapper {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #f5f5f5;
  border-radius: 48rpx;
  padding: 8rpx 12rpx 8rpx 28rpx;
  transition: all 0.3s ease;
  border: 1rpx solid transparent;
}

.input-wrapper:focus-within {
  background: #fff;
  border-color: #667eea;
  box-shadow: 0 0 0 4rpx rgba(102, 126, 234, 0.1);
}

.input-field {
  flex: 1;
  height: 76rpx;
  font-size: 30rpx;
  color: #333;
  background: transparent;
}

.input-placeholder {
  color: #aaa;
  font-size: 28rpx;
}

.send-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #e0e0e0;
  transition: all 0.3s ease;
}

.send-btn.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.send-icon {
  font-size: 32rpx;
  color: #fff;
  transform: rotate(-90deg);
}

.input-hint {
  text-align: center;
  margin-top: 16rpx;
}

.input-hint text {
  font-size: 22rpx;
  color: #aaa;
}

.quick-actions {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  padding: 20rpx 24rpx;
  background: rgba(255, 255, 255, 0.96);
}

.quick-btn {
  padding: 16rpx 28rpx;
  background: #f0f0f0;
  border-radius: 48rpx;
  font-size: 26rpx;
  color: #667eea;
}

/* ==================== 底部输入区域（修改这部分） ==================== */
.input-area {
  background: rgba(255, 255, 255, 0.96);
  backdrop-filter: blur(20px);
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
  padding: 20rpx 24rpx 32rpx;
  /* 新增：底部安全区域适配 */
  padding-bottom: calc(32rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

/* 快捷操作按钮区域（如果有的话） */
.quick-actions {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  padding: 20rpx 24rpx;
  background: rgba(255, 255, 255, 0.96);
  /* 新增：底部安全区域适配 */
  padding-bottom: calc(20rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}