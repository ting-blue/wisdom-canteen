/* pages/tuijian/tuijian.wxss */
.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding: 20rpx;
}

.food-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.food-card {
  background-color: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.food-img-wrapper {
  width: 100%;
  height: 300rpx;
  overflow: hidden;
}

.food-img {
  width: 100%;
  height: 100%;
}

.food-info {
  padding: 24rpx;
}

.food-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 16rpx;
}

.food-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.food-price {
  font-size: 32rpx;
  color: #ff6b6b;
  font-weight: bold;
}

/* 营养信息网格 */
.nutrition-grid {
  display: flex;
  justify-content: space-around;
  background-color: #f8f8f8;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.nutrition-item {
  text-align: center;
}

.nutrition-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff6b6b;
  display: block;
}

.nutrition-label {
  font-size: 22rpx;
  color: #999;
}

/* 重量选择器 */
.weight-selector {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
  padding: 16rpx;
  background-color: #f8f8f8;
  border-radius: 16rpx;
}

.weight-label {
  font-size: 26rpx;
  color: #666;
}

.weight-selector slider {
  flex: 1;
}

.weight-unit {
  font-size: 26rpx;
  color: #666;
}

/* 热量明细 */
.calorie-detail {
  background-color: #fff8e8;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
}

.detail-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #ff9800;
  display: block;
  margin-bottom: 8rpx;
}

.detail-text {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin: 4rpx 0;
}

.detail-text.total {
  color: #ff6b6b;
  font-weight: bold;
  margin-top: 8rpx;
  padding-top: 8rpx;
  border-top: 1rpx solid #ffe0b3;
}

.food-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
  line-height: 1.4;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #eee;
}

.spiciness, .rating {
  font-size: 24rpx;
  color: #999;
}

.more {
  font-size: 24rpx;
  color: #ff6b6b;
}